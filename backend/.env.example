# Copy this file to .env and fill in real API keys/paths before starting the backend.
# Do NOT commit your real keys to source control.

# Google service account JSON path (absolute or relative). Example:
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini (Google) API key for the GenerativeModel
# GEMINI_API_KEY=

# ElevenLabs TTS API key
# ELEVENLABS_API_KEY=

# Optional: any other env vars used by your app
